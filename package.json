{
  "name": "@singi-labs/sifa-page-renderer",
  "version": "0.2.27",
  "description": "Pure HTML renderer for personal sites driven by Sifa profile data. No framework, no filesystem -- import and call.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/singi-labs/sifa-page",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/singi-labs/sifa-page-renderer.git"
  },
  "bugs": {
    "url": "https://github.com/singi-labs/sifa-page/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "sifa",
    "atproto",
    "personal-site",
    "page",
    "renderer"
  ],
  "files": [
    "dist",
    "static",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/render.d.ts",
        "default": "./dist/render.js"
      }
    },
    "./style": {
      "import": {
        "types": "./dist/style.d.ts",
        "default": "./dist/style.js"
      }
    },
    "./static/*": "./static/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --max-workers=2",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@singi-labs/sifa-sdk": "0.12.15",
    "isomorphic-dompurify": "3.18.0",
    "marked": "16.4.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.8"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "fsevents@2.3.3": true
  }
}
